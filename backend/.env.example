# App
ENVIRONMENT=local
DEBUG=true
# Comma-separated frontend origins allowed to call this API (required outside local)
CORS_ORIGINS=

# Supabase Postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/creator_intelligence

# Supabase Auth (JWT validation)
SUPABASE_JWT_SECRET=change-me
SUPABASE_URL=https://your-project.supabase.co

# Upstash Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# AI Layer
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4-6

# External APIs
YOUTUBE_API_KEY=
# X (Twitter) trends need a paid API plan — leave empty to disable the source
X_BEARER_TOKEN=
# Facebook has no public trending API — placeholder for a future Graph API integration
FACEBOOK_ACCESS_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=creator-intelligence/0.1

# Payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Email
RESEND_API_KEY=
EMAIL_FROM=noreply@example.com

# Observability
SENTRY_DSN=
